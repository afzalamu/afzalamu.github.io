                    },
                    "education": {
                        "type": "dir",
                        "children": {
                            "amu_btech.txt": {
                                "type": "file",
                                "content": `DEGREE: Bachelor of Technology
MAJOR: Electronics Engineering
INSTITUTE: Aligarh Muslim University
