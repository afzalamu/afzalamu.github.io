<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Afzal Malik @ Terminal</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* --- THEME --- */
        :root {
            --bg-term: #0d1117;
            --bg-nav: #161b22;
            --bg-gvim: #282a36;
            --text-main: #f8f8f2;
            --text-muted: #6272a4;
            --text-cyan: #8be9fd;
            --text-green: #50fa7b;
            --text-orange: #ffb86c;
            --text-pink: #ff79c6;
            --text-purple: #bd93f9;
            --text-red: #ff5555;
            --text-ghost: #6e7681; /* Color for autocomplete suggestion */
            --prompt-user: #58a6ff;
            --prompt-host: #d2a8ff;
            --prompt-path: #7ee787;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: var(--bg-term);
            color: var(--text-main);
            font-family: 'Fira Code', monospace;
            font-size: 14px;
            height: 100dvh; 
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        /* --- TOP NAVIGATION BAR --- */
        nav {
            height: 60px;
            min-height: 60px;
            background-color: var(--bg-nav);
            border-bottom: 1px solid #30363d;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
            z-index: 1000;
        }

        .nav-logo {
            font-weight: 700;
            font-size: 18px;
            color: var(--text-green);
            text-decoration: none;
            border: 1px solid var(--text-green);
            padding: 5px 10px;
            border-radius: 4px;
            white-space: nowrap;
        }

        .nav-links {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .nav-item {
            color: var(--text-main);
            text-decoration: none;
            font-size: 14px;
            transition: color 0.2s;
            display: flex;
            align-items: center;
        }

        .nav-item:hover { color: var(--text-cyan); }
        .nav-item i { margin-right: 6px; font-size: 16px; }

        /* --- TERMINAL AREA --- */
        #terminal-container {
            flex-grow: 1;
            padding: 15px;
            overflow-y: auto;
            overflow-x: hidden;
            position: relative;
            z-index: 1;
            display: none; 
            -webkit-overflow-scrolling: touch;
            padding-bottom: 100px; /* Space for keyboard */
        }
        
        #terminal-container::-webkit-scrollbar { width: 6px; }
        #terminal-container::-webkit-scrollbar-thumb { background: #30363d; border-radius: 4px; }

        .output-line { 
            margin-bottom: 4px; 
            white-space: pre-wrap; 
            word-wrap: break-word;
            line-height: 1.5; 
        }

        /* --- NEW PROMPT LAYOUT FOR INLINE SUGGESTION --- */
        .prompt-line { 
            display: flex; 
            align-items: center; 
            margin-top: 5px; 
            flex-wrap: wrap; 
        }
        
        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
            flex-grow: 1;
            margin-left: 8px;
        }

        input#cmd-input {
            background: transparent;
            border: none;
            color: white;
            font-family: 'Fira Code', monospace;
            font-size: 14px;
            outline: none;
            padding: 0;
            margin: 0;
            min-width: 1px; /* Allow shrinking */
            width: 10px; /* Start small, grow via JS */
        }

        /* The Ghost Text (Suggestion) */
        #inline-suggestion {
            color: var(--text-ghost);
            font-family: 'Fira Code', monospace;
            font-size: 14px;
            white-space: pre;
            cursor: pointer;
            pointer-events: auto; /* clickable */
        }

        /* ASCII Art */
        .ascii-art {
            color: var(--prompt-path);
            font-weight: bold;
            margin-bottom: 20px;
            white-space: pre;
            line-height: 1.2;
        }

        /* Colors */
        .ls-dir { color: var(--prompt-user); font-weight: bold; }
        .ls-file { color: var(--text-main); }
        .error { color: #ff7b72; }
        .user { color: var(--prompt-user); font-weight: bold; }
        .host { color: var(--prompt-host); font-weight: bold; }
        .path { color: var(--prompt-path); }

        /* Hidden span to calculate text width */
        #width-calculator {
            position: absolute;
            visibility: hidden;
            height: auto;
            width: auto;
            white-space: pre;
            font-family: 'Fira Code', monospace;
            font-size: 14px;
        }

        /* --- BOOT SCREEN --- */
        #boot-screen {
            position: fixed;
            top: 60px; 
            left: 0; width: 100%; height: calc(100% - 60px);
            background: var(--bg-term);
            padding: 20px;
            z-index: 10;
        }

        /* --- GVIM WINDOW --- */
        #gvim-overlay {
            display: none;
            position: fixed;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 80%; height: 80%;
            background-color: var(--bg-gvim);
            border: 1px solid #44475a;
            box-shadow: 0 20px 50px rgba(0,0,0,0.9);
            z-index: 3000;
            flex-direction: column;
            font-size: 14px;
        }

        .gvim-header {
            background-color: #44475a;
            padding: 8px 15px;
            font-size: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .window-controls {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .close-btn {
            background: none;
            border: none;
            color: var(--text-red);
            font-size: 18px;
            cursor: pointer;
            padding: 5px;
        }

        .gvim-body {
            flex-grow: 1;
            padding: 10px;
            overflow-y: auto;
            white-space: pre-wrap;
            display: flex;
            -webkit-overflow-scrolling: touch;
        }

        .line-numbers {
            color: var(--text-muted);
            text-align: right;
            padding-right: 10px;
            border-right: 1px solid #44475a;
            margin-right: 10px;
            min-width: 30px;
            user-select: none;
            font-size: 12px;
        }

        .code-content { flex-grow: 1; outline: none; font-size: 13px; }

        .gvim-status-bar {
            background-color: #44475a;
            padding: 4px 10px;
            font-size: 11px;
            display: flex;
            justify-content: space-between;
            color: var(--text-cyan);
        }

        /* Syntax Highlighting */
        .syn-header { color: var(--text-pink); font-weight: bold; }
        .syn-bullet { color: var(--text-cyan); }
        .syn-string { color: var(--text-green); }
        .syn-label { color: var(--text-orange); font-weight: bold; }
        .syn-num { color: var(--text-purple); }
        .syn-link { color: #58a6ff; text-decoration: underline; cursor: pointer; }

        /* --- MOBILE MEDIA QUERIES --- */
        @media (max-width: 768px) {
            nav { padding: 0 15px; }
            .nav-item span { display: none; } 
            .nav-item i { margin-right: 0; font-size: 20px; } 
            .nav-links { gap: 25px; }

            body { font-size: 12px; }
            input#cmd-input, #inline-suggestion, #width-calculator { font-size: 12px; }
            .ascii-art { font-size: 10px; }
            
            #gvim-overlay { width: 95%; height: 85%; }
            .line-numbers { min-width: 25px; margin-right: 5px; padding-right: 5px; }
        }

        @media (max-width: 400px) {
            .ascii-art { display: none; }
            .nav-logo { font-size: 16px; }
        }

    </style>
</head>
<body>

    <nav>
        <a href="#" class="nav-logo" onclick="location.reload()">AM.</a>
        <div class="nav-links">
            <a href="mailto:afzalmalik68099@gmail.com" class="nav-item" title="Email"><i class="fa-solid fa-envelope"></i> <span>Email</span></a>
            <a href="https://www.linkedin.com/in/malik-afzal/" target="_blank" class="nav-item" title="LinkedIn"><i class="fa-brands fa-linkedin"></i> <span>LinkedIn</span></a>
            <a href="https://github.com/afzalamu" target="_blank" class="nav-item" title="GitHub"><i class="fa-brands fa-github"></i> <span>GitHub</span></a>
            <a href="assets/pdf/AfzalMalik_Resume.pdf" target="_blank" class="nav-item" style="color: var(--text-green)" title="Resume"><i class="fa-solid fa-file-pdf"></i> <span>Resume</span></a>
        </div>
    </nav>

    <div id="boot-screen"></div>

    <div id="terminal-container" onclick="focusInput()">
        <div class="ascii-art">
   _____  ____ ______ ___   _      
  /  _  \|   |/  /   /  /  / \     
 /  /_\  \   <  /   /  /  /  /     
/    |    \   \ \  /  /__/  /__    
\____|__  /__| \ \/____/____/  /   
        \/      \/             \/    
        </div>
        <div style="margin-bottom: 20px;">
            Afzal Malik | Design Engineer [Version 4.1.0]<br>
            (c) 2026 Afzal Malik. All rights reserved.<br><br>
            Type <span style="color: var(--text-green)">'help'</span> for a list of commands.<br>
            Type <span style="color: var(--text-pink)">'ls'</span> to see files.<br>
            Use <span style="color: var(--text-pink)">'gvim filename.txt'</span> to view details.<br>
            -------------------------------------------------
        </div>
        
        <div id="history"></div>

        <div class="prompt-line">
            <span class="user">visitor</span><span style="color:white">@</span><span class="host">afzal.dev</span><span style="color:white">:</span><span class="path" id="current-path">~</span><span style="color:white">$</span>
            
            <div class="input-wrapper">
                <input type="text" id="cmd-input" autocomplete="off" spellcheck="false" autocapitalize="none">
                <span id="inline-suggestion"></span>
            </div>
        </div>
    </div>

    <span id="width-calculator"></span>

    <div id="gvim-overlay">
        <div class="gvim-header">
            <span id="gvim-filename">[No Name]</span>
            <div class="window-controls">
                <span style="opacity: 0.6; font-size: 11px;">READ ONLY</span>
                <button class="close-btn" onclick="closeGvim()" title="Close Window">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        </div>
        <div class="gvim-body">
            <div class="line-numbers" id="gvim-lines"></div>
            <div class="code-content" id="gvim-content"></div>
        </div>
        <div class="gvim-status-bar">
            <span>-- TEXT VIEW --</span>
            <span id="gvim-file-status">100%</span>
        </div>
    </div>

    <script>
        // --- 1. FILE SYSTEM CONTENT ---
        const fileSystem = {
            "~": {
                "type": "dir",
                "children": {
                    "README.txt": {
                        "type": "file",
                        "content": `WELCOME TO MY TERMINAL PORTFOLIO

