                            }
                        }
                    },
                    "skills": {
                        "type": "dir",
                        "children": {
                            "technical_stack.txt": {
                                "type": "file",
                                "content": `[LANGUAGES]
* Verilog HDL
* C / C++
* Python
* Tcl Scripting
* Bash Scripting

[TOOLS]
* Cadence Virtuoso
* LT Spice
* Glade Layout
* Xilinx Vivado
* Electric Binary

[TECHNOLOGIES]
* FinFET 7nm
* CMOS 180nm / 28nm
* FPGA (Xilinx Artix-7)`
