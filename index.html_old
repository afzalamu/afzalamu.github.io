                        }
                    },
                    "projects": {
                        "type": "dir",
                        "children": {
                            "sram_memory_7nm.txt": {
                                "type": "file",
                                "content": `PROJECT: 2048x128 SRAM Memory Design in 7nm FinFET
COMPANY: Associated with Zia Semiconductor Pvt Ltd
