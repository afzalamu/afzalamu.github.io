                    }
                }
            }
        };

        // --- 2. BOOT LOGIC ---
        const bootScreen = document.getElementById('boot-screen');
        const terminalContainer = document.getElementById('terminal-container');
        
        const bootMessages = [
            "Initializing Kernel...",
            "Loading Modules: graphics, network, input...",
            "Mounting file system: /dev/sda1 (Afzal_Portfolio)...",
            "Checking memory... 32GB OK",
            "Starting visual interface...",
            "Welcome, Visitor."
        ];

        async function runBoot() {
            for (let msg of bootMessages) {
                const p = document.createElement('div');
                p.className = "output-line";
                p.style.color = "#6272a4";
                p.innerText = `[ OK ] ${msg}`;
                bootScreen.appendChild(p);
                await new Promise(r => setTimeout(r, 300));
            }
            await new Promise(r => setTimeout(r, 500));
            bootScreen.style.display = "none";
            terminalContainer.style.display = "block";
            document.getElementById('cmd-input').focus();
        }

        // --- 3. TERMINAL LOGIC ---
        let currentPath = ["~"];
        let historyStack = [];
        let historyIdx = -1;
        let isGvimOpen = false;
        let gvimBuffer = "";

        const cmdInput = document.getElementById('cmd-input');
        const historyDiv = document.getElementById('history');
        const pathSpan = document.getElementById('current-path');
        const inlineSuggestion = document.getElementById('inline-suggestion');
        const widthCalculator = document.getElementById('width-calculator');
        const gvimModal = document.getElementById('gvim-overlay');
        const gvimContent = document.getElementById('gvim-content');
        const gvimLines = document.getElementById('gvim-lines');
        const gvimFilename = document.getElementById('gvim-filename');

        function focusInput() {
            // Prevent focusing if selecting text
            const selection = window.getSelection();
            if (selection.type !== 'Range') {
                cmdInput.focus();
            }
        }

        function getDirFromPath(pathArray) {
            let current = fileSystem["~"];
            for (let i = 1; i < pathArray.length; i++) {
                if (current.children && current.children[pathArray[i]]) {
                    current = current.children[pathArray[i]];
                } else {
                    return null;
                }
            }
            return current;
        }

        function printOutput(text, type = "") {
            const div = document.createElement('div');
            div.className = "output-line " + type;
            div.innerHTML = text; 
            historyDiv.appendChild(div);
            terminalContainer.scrollTop = terminalContainer.scrollHeight;
        }

        // --- INLINE SUGGESTION LOGIC ---
        function updateInputWidth() {
            // Copy text to hidden span to calculate width
            widthCalculator.innerText = cmdInput.value || '';
            // Add a small buffer (10px) to prevent cutting off cursor
            const width = widthCalculator.getBoundingClientRect().width;
            cmdInput.style.width = Math.max(10, width + 5) + "px";
        }

        function updateSuggestion() {
            const val = cmdInput.value;
            const lastSpaceIndex = val.lastIndexOf(' ');
            const currentWord = val.substring(lastSpaceIndex + 1);

            // Reset
            inlineSuggestion.innerText = "";

            if (currentWord.length > 0) {
                const dir = getDirFromPath(currentPath);
                if (dir && dir.children) {
                    const matches = Object.keys(dir.children).filter(k => k.startsWith(currentWord));
                    if (matches.length > 0) {
                        // Get the first match
                        let match = matches[0];
                        // If it's a directory, append slash for visual clarity
                        if (dir.children[match].type === 'dir') match += '/';
                        
                        // We only want to show the suffix that hasn't been typed yet
                        const suffix = match.substring(currentWord.length);
                        inlineSuggestion.innerText = suffix;
                    }
                }
            }
        }

        // Tap on suggestion to complete
        inlineSuggestion.addEventListener('click', () => {
            cmdInput.value += inlineSuggestion.innerText;
            inlineSuggestion.innerText = "";
            updateInputWidth();
            cmdInput.focus();
        });

        cmdInput.addEventListener('input', () => {
            updateInputWidth();
            updateSuggestion();
        });

        // Syntax Highlighter for Text Files + LINKS
        function colorize(text) {
            let code = text.replace(/</g, "&lt;").replace(/>/g, "&gt;");
            
            code = code.replace(/(\[.*?\])/g, '<span class="syn-header">$1</span>');
            code = code.replace(/^([A-Z\s]+):/gm, '<span class="syn-label">$1:</span>');
            code = code.replace(/^(\s*[\*\-])/gm, '<span class="syn-bullet">$1</span>');
            code = code.replace(/\b(\d+)\b/g, '<span class="syn-num">$1</span>');
            const urlRegex = /(https?:\/\/[^\s]+)/g;
            code = code.replace(urlRegex, '<a href="$1" target="_blank" class="syn-link">$1</a>');
            
            return code;
        }

        function openGvim(filename, content) {
            isGvimOpen = true;
            gvimModal.style.display = "flex";
            gvimFilename.innerText = filename;
            gvimContent.innerHTML = colorize(content);
            
            const lineCount = content.split('\n').length;
            let linesHtml = "";
            for(let i=1; i<=lineCount; i++) linesHtml += i + "<br>";
            gvimLines.innerHTML = linesHtml;
        }

        function closeGvim() {
            isGvimOpen = false;
            gvimModal.style.display = "none";
            gvimBuffer = "";
            cmdInput.focus();
        }

        const commands = {
            ls: () => {
                const dir = getDirFromPath(currentPath);
                if (!dir || !dir.children) return;
                
                let output = Object.entries(dir.children).map(([name, item]) => {
                    return item.type === 'dir' 
                        ? `<span class="ls-dir">${name}/</span>` 
                        : `<span class="ls-file">${name}</span>`;
                }).join('  ');
                printOutput(output);
            },
            pwd: () => printOutput(currentPath.join('/')),
            cd: (args) => {
                if (!args[0]) { currentPath = ["~"]; pathSpan.innerText = "~"; return; }
                const parts = args[0].split('/').filter(p => p !== "");
                let tempPath = [...currentPath];
                
                for (let part of parts) {
                    if (part === ".") continue;
                    if (part === "..") {
                        if (tempPath.length > 1) tempPath.pop();
                    } else if (part === "~") {
                        tempPath = ["~"];
                    } else {
                        const currDir = getDirFromPath(tempPath);
                        if (currDir.children && currDir.children[part] && currDir.children[part].type === 'dir') {
                            tempPath.push(part);
                        } else {
                            printOutput(`bash: cd: ${part}: No such directory`, "error");
                            return; 
                        }
                    }
                }
                currentPath = tempPath;
                pathSpan.innerText = currentPath.join('/');
            },
            gvim: (args) => {
                if (!args[0]) { printOutput("usage: gvim <filename>"); return; }
                const dir = getDirFromPath(currentPath);
                const file = dir.children[args[0]];
                if (file && file.type === 'file') openGvim(args[0], file.content);
                else printOutput(`gvim: ${args[0]}: No such file`, "error");
            },
            cat: (args) => {
                if (!args[0]) { printOutput("usage: cat <filename>"); return; }
                const dir = getDirFromPath(currentPath);
                const file = dir.children[args[0]];
                if (file && file.type === 'file') printOutput(file.content);
                else printOutput(`cat: ${args[0]}: No such file`, "error");
            },
            help: () => {
                printOutput(`
  Commands:
  ls           List directory contents
  cd [path]    Change directory (use 'cd ../' to go back)
  gvim [file]  Open file in graphical editor
  cat [file]   Print file content to terminal
  pwd          Print working directory
  clear        Clear screen
                `);
            },
            clear: () => historyDiv.innerHTML = ""
        };

        cmdInput.addEventListener('keydown', (e) => {
            if (isGvimOpen) return;

            if (e.key === 'Enter') {
                const raw = cmdInput.value;
                // Auto complete if enter is pressed and suggestion exists? 
                // Usually shell runs command. We clear suggestion.
                inlineSuggestion.innerText = "";
                
                const parts = raw.trim().split(/\s+/);
                const cmd = parts[0];
                const args = parts.slice(1);
                
                printOutput(`<span class="user">visitor</span><span style="color:white">@</span><span class="host">afzal.dev</span>:<span class="path">${currentPath.join('/')}</span>$ ${raw}`);
                
                if (raw.trim() !== "") {
                    historyStack.push(raw);
                    historyIdx = historyStack.length;
                    if (commands[cmd]) commands[cmd](args);
                    else printOutput(`bash: ${cmd}: command not found`, "error");
                }
                cmdInput.value = "";
                updateInputWidth();
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                if (historyIdx > 0) {
                    cmdInput.value = historyStack[--historyIdx];
                    updateInputWidth();
                }
            } else if (e.key === 'ArrowDown') {
                e.preventDefault();
                if (historyIdx < historyStack.length - 1) {
                    cmdInput.value = historyStack[++historyIdx];
                    updateInputWidth();
                } else {
                    cmdInput.value = "";
                    updateInputWidth();
                }
            } else if (e.key === 'Tab') {
                e.preventDefault();
                // If suggestion is visible, tab completes it
                if (inlineSuggestion.innerText !== "") {
                    cmdInput.value += inlineSuggestion.innerText;
                    inlineSuggestion.innerText = "";
                    updateInputWidth();
                }
            }
        });

        window.addEventListener('keypress', (e) => {
            if (!isGvimOpen) return;
            gvimBuffer += e.key;
            if (gvimBuffer.endsWith(":q") && e.key === "Enter") closeGvim();
            if (e.key === "Escape") closeGvim();
        });

        runBoot();

    </script>
</body>
</html>
